# Sample reverse proxy + automatic TLS for a production deploy (PR0-9).
#
# Caddy obtains and renews HTTPS certificates automatically. It serves the
# frontend at / and the API under /api (stripping the prefix so the backend's
# root-level routes work unchanged). Build the frontend image with
# NEXT_PUBLIC_API_URL=https://studio.example.com/api so the browser calls the API
# through this proxy, and set CORS_ORIGINS=https://studio.example.com on the API.
#
# Run: caddy run --config deploy/Caddyfile   (or use the official caddy image)

studio.example.com {
	encode gzip

	handle_path /api/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
